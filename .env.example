# Frontend Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Frontend API Configuration
VITE_API_BASE_URL=http://localhost:3001

# Backend public URL used in emailed links.
SERVER_URL=http://localhost:3001

# Long random secret used to sign self-service booking cancellation links.
CANCEL_SECRET=replace-with-a-long-random-secret

# Optional frontend-only admin allowlist for redirecting non-admin users away from the admin UI.
# The backend ADMIN_EMAILS allowlist remains authoritative.
VITE_ADMIN_EMAILS=
